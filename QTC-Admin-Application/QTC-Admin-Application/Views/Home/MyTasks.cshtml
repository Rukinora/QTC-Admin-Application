@model QTC_Admin_Application.Models.MyTasksViewModel

@{
    ViewData["Title"] = "My Tasks";
}

<div class="container mt-4">
    <h3 style="color: #6f42c1;"><i class="bi bi-list-task"></i> My Tasks</h3>
    <p class="text-muted">Active tasks currently assigned to you for processing.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-info mt-4">
        <div class="card-body p-0">
            <table class="table mb-0 table-hover table-striped">
                <thead class="table-light border-bottom">
                    <tr>
                        <th>Item Key</th>
                        <th>Workflow Name</th>
                        <th>Step Name</th>
                        <th>Status</th>
                        <th>Last Updated</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Tasks == null || !Model.Tasks.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5 border-0">
                            <i class="bi bi-emoji-smile text-success" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0 fs-5 text-dark">You have no active tasks currently assigned to you.</p>
                            <p class="text-muted">Great job staying on top of your workload!</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">
                                <i class="bi bi-file-earmark-text"></i> @task.ItemKey
                            </td>
                            <td class="fw-semibold" style="color: #6f42c1;">@task.WorkflowName</td>
                            <td>@task.StepName</td>
                            <td>
                                <span class="badge @(task.StatusName == "Pending" ? "bg-secondary" : "bg-warning text-dark")">
                                    @task.StatusName
                                </span>
                            </td>
                            <td class="text-muted small">@task.UpdatedDate.ToString("g")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>