@model QTC_Admin_Application.Models.Workflow
@{
    ViewData["Title"] = Model.WorkflowName;
    var workflowTasks = ViewData["WorkflowTasks"] as List<QTC_Admin_Application.Models.Task> ?? new List<QTC_Admin_Application.Models.Task>();
    var activityLogs = ViewData["ActivityLogs"] as List<QTC_Admin_Application.Models.ActivityLog> ?? new List<QTC_Admin_Application.Models.ActivityLog>();
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Back Button -->
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Workflows
        </a>
    </div>

    <!-- Export Compliance Report -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-download"></i> Export Workflow Compliance Report
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="ExportWorkflowReport" method="get" class="row g-3 align-items-end">
                <input type="hidden" name="id" value="@Model.WorkflowId" />

                <div class="col-md-3">
                    <label for="fromDate" class="form-label">From Date</label>
                    <input type="date" id="fromDate" name="fromDate" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label for="toDate" class="form-label">To Date</label>
                    <input type="date" id="toDate" name="toDate" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label for="format" class="form-label">Format</label>
                    <select id="format" name="format" class="form-select">
                        <option value="csv">CSV (.csv)</option>
                        <option value="pdf">PDF (.pdf)</option>
                    </select>
                </div>

                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-primary" style="background-color: #6f42c1; border-color: #6f42c1;">
                        <i class="bi bi-file-earmark-arrow-down"></i> Export Report
                    </button>
                </div>
            </form>

            <div class="form-text mt-2">
                Exports task-level workflow data including status, timestamps, and assigned users.
                Date range filters tasks by created / updated / assigned / completed timestamps.
            </div>
        </div>
    </div>

    <!-- Workflow Header Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header" style="background-color: #6f42c1; color: white;">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-diagram-3"></i> @Model.WorkflowName
                </h4>
                <a asp-action="Edit" asp-route-id="@Model.WorkflowId" class="btn btn-light btn-sm">
                    <i class="bi bi-pencil"></i> Edit Workflow
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Description:</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.WorkflowType))
                            {
                                <span class="d-inline-block text-break" style="max-width: 100%;">@Model.WorkflowType</span>
                            }
                            else
                            {
                                <span class="text-muted">Not specified</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Record Limit:</dt>
                        <dd class="col-sm-8">@Model.RecordLimit</dd>

                        <dt class="col-sm-4">Created By:</dt>
                        <dd class="col-sm-8">@Model.CreatedBy</dd>

                        <dt class="col-sm-4">Created Date:</dt>
                        <dd class="col-sm-8">@Model.CreatedDate.ToString("g")</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Updated By:</dt>
                        <dd class="col-sm-8">@(Model.UpdatedBy ?? "-")</dd>

                        <dt class="col-sm-4">Updated Date:</dt>
                        <dd class="col-sm-8">@(Model.UpdatedDate?.ToString("g") ?? "-")</dd>

                        <dt class="col-sm-4">Sub Status ID:</dt>
                        <dd class="col-sm-8">@(Model.SubStatusId?.ToString() ?? "-")</dd>

                        <dt class="col-sm-4">Total Steps:</dt>
                        <dd class="col-sm-8">
                            <span class="badge" style="background-color: #6f42c1;">
                                @(Model.WorkflowSteps?.Count ?? 0)
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <!-- Workflow Steps Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-list-ol"></i> Workflow Steps
            </h5>
            <a asp-action="CreateStep" asp-route-workflowId="@Model.WorkflowId" class="btn btn-sm btn-primary" style="background-color: #6f42c1; border-color: #6f42c1;">
                <i class="bi bi-plus-circle"></i> Add New Step
            </a>
        </div>
        <div class="card-body p-0">
            @if (Model.WorkflowSteps != null && Model.WorkflowSteps.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 100px;">Sequence</th>
                                <th>Step Name</th>
                                <th>Description</th>
                                <th style="width: 120px;">Type</th>
                                <th style="width: 100px;">Enabled</th>
                                <th style="width: 200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.WorkflowSteps.OrderBy(s => s.Sequence))
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@step.Sequence</span>
                                    </td>
                                    <td>
                                        <strong>@step.StepName</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(step.StepDesc))
                                        {
                                            <span>@step.StepDesc</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">No description</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(step.StepType))
                                        {
                                            <span class="badge bg-info">@step.StepType</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (step.Enabled == "Y")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Yes
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle"></i> No
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="EditStep"
                                               asp-route-workflowStepId="@step.WorkflowStepId"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Edit Step">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="DeleteStep" method="post" style="display:inline;">
                                                <input type="hidden" name="workflowStepId" value="@step.WorkflowStepId" />
                                                <input type="hidden" name="workflowId" value="@Model.WorkflowId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        title="Delete Step"
                                                        onclick="return confirm('Are you sure you want to delete this step?');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-2">No workflow steps have been added yet.</p>
                    <p class="text-muted small">Click "Add New Step" to create the first step for this workflow.</p>
                </div>
            }
        </div>
    </div>

    <!-- Workflow Tasks Section -->
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-list-task"></i> Workflow Tasks
            </h5>
        </div>
        <div class="card-body p-0">
            @if (workflowTasks.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Item Key</th>
                                <th>Assigned To</th>
                                <th>Status</th>
                                <th>Step</th>
                                <th style="width: 220px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in workflowTasks)
                            {
                                var isCompleted = task.StatusId == 3;
                                <tr>
                                    <td>
                                        <span class="d-inline-block text-truncate" style="max-width: 150px;" title="@(task.Item?.ItemKey ?? task.ItemId.ToString())">
                                            @(task.Item?.ItemKey ?? $"Item #{task.ItemId}")
                                        </span>
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(task.AssignedTo))
                                        {
                                            <span class="text-muted fst-italic">Unassigned</span>
                                        }
                                        else
                                        {
                                            <strong>@task.AssignedTo</strong>
                                        }
                                    </td>
                                    <td>
                                        @if (task.StatusId == 1)
                                        {
                                            <span class="badge bg-secondary">@(task.Status?.StatusName ?? "Pending")</span>
                                        }
                                        else if (task.StatusId == 2)
                                        {
                                            <span class="badge bg-warning text-dark">@(task.Status?.StatusName ?? "In Progress")</span>
                                        }
                                        else if (task.StatusId == 3)
                                        {
                                            <span class="badge bg-success">@(task.Status?.StatusName ?? "Completed")</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@(task.Status?.StatusName ?? "-")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (task.WorkflowStep != null)
                                        {
                                            <span class="d-inline-block text-truncate" style="max-width: 250px;" title="@task.WorkflowStep.StepName">
                                                @task.WorkflowStep.StepName
                                            </span>
                                            <div class="small text-muted">Seq: @task.WorkflowStep.Sequence</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isCompleted)
                                        {
                                            <div class="text-success small fw-bold">
                                                <i class="bi bi-check-circle-fill"></i> Completed
                                                <div><span class="text-muted fw-normal">on @(task.CompletedDate?.ToString("g") ?? task.UpdatedDate.ToString("g"))</span></div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                <form asp-action="ReassignTask" method="post" class="d-flex gap-1 align-items-center">
                                                    <input type="hidden" name="taskId" value="@task.TaskId" />
                                                    <input type="hidden" name="workflowId" value="@Model.WorkflowId" />
                                                    <input type="text"
                                                           name="assignedTo"
                                                           class="form-control form-control-sm"
                                                           value="@(task.AssignedTo ?? string.Empty)"
                                                           placeholder="Username"
                                                           style="max-width: 120px;" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Reassign Task">
                                                        <i class="bi bi-person-gear"></i> Reassign
                                                    </button>
                                                </form>
                                                <div class="btn-group" role="group">
                                                    @if (!string.IsNullOrWhiteSpace(task.AssignedTo))
                                                    {
                                                        <form asp-action="UnassignTask" method="post" style="display:inline;">
                                                            <input type="hidden" name="taskId" value="@task.TaskId" />
                                                            <input type="hidden" name="workflowId" value="@Model.WorkflowId" />
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Unassign Task">
                                                                <i class="bi bi-person-dash"></i> Unassign
                                                            </button>
                                                        </form>
                                                    }
                                                    <form asp-action="CompleteTask" method="post" style="display:inline;">
                                                        <input type="hidden" name="taskId" value="@task.TaskId" />
                                                        <input type="hidden" name="workflowId" value="@Model.WorkflowId" />
                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-success"
                                                                title="Complete Task"
                                                                onclick="return confirm('Mark this task as complete?');">
                                                            <i class="bi bi-check2-circle"></i> Complete
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-inbox"></i>
                    <p class="mb-0 mt-2">No tasks found for this workflow.</p>
                </div>
            }
        </div>
    </div>

    <!-- Workflow History Section (Requirement #13) -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-clock-history"></i> Activity History
            </h5>
        </div>
        <div class="card-body p-0">
            @if (activityLogs.Any())
            {
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th>Date/Time</th>
                                <th>Action</th>
                                <th>Step Name</th>
                                <th>User</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in activityLogs)
                            {
                                <tr>
                                    <td class="text-muted small">@log.CreatedDate.ToString("g")</td>
                                    <td>
                                        @if (log.Action == "Complete")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Completed</span>
                                        }
                                        else if (log.Action == "Assign")
                                        {
                                            <span class="badge bg-primary"><i class="bi bi-person-check"></i> Assigned</span>
                                        }
                                        else if (log.Action == "Unassign")
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-person-x"></i> Unassigned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark">@log.Action</span>
                                        }
                                    </td>
                                    <td>
                                        @if (log.WorkflowStep != null)
                                        {
                                            <span title="Seq: @log.WorkflowStep.Sequence">@log.WorkflowStep.StepName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Unknown Step</span>
                                        }
                                    </td>
                                    <td>
                                        <strong>@log.ActivityUser</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-journal-x" style="font-size: 1.5rem;"></i>
                    <p class="mb-0 mt-2">No activity recorded for this workflow yet.</p>
                </div>
            }
        </div>
    </div>

    <!-- Info Alert -->
    <div class="alert alert-info mt-4" role="alert">
        <i class="bi bi-info-circle"></i>
        <strong>Note:</strong> Workflow steps define the sequence of actions in this workflow.
        Steps are executed in order based on their sequence number.
    </div>
</div>
