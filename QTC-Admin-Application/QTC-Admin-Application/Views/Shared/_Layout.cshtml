@{
    var role = Context.Session.GetString("Role");
    bool isAdmin = role == "Admin";
    bool isLoggedIn = Context.Session.GetString("LoggedIn") == "true";
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Leidos QTC Admin Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QTC_Admin_Application.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #6f42c1;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="color: white;">
                    <i class="bi bi-diagram-3-fill me-2"></i>Leidos QTC Health Services
                    <span class="badge bg-light text-dark ms-2" style="font-size: 0.6rem;">Admin Portal</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="MonthlyPerformanceReport">
                                <i class="bi bi-graph-up"></i> Monthly Report
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock"></i> Privacy
                            </a>
                        </li>
                        @if (Context.Session.GetString("Username")?.ToLower() == "ruben")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Analytics"
                                   asp-action="Dashboard">
                                    <i class="bi bi-graph-up-arrow"></i> Investor Dashboard
                                </a>
                            </li>
                        }
                        @if (isAdmin){
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="WorkloadDashboard">
                                    <i class="bi bi-person"></i> Users
                                </a>
                            </li>
                        }
                        @if (isLoggedIn && !isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="MyTasks">
                                    <i class="bi bi-list-task"></i> MyTasks
                                </a>
                            </li>
                        }
                    </ul>
                    @if (Context.Session.GetString("LoggedIn") == "true")
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="navbar-text me-3 text-white">
                                    <i class="bi bi-person-circle"></i> @Context.Session.GetString("Username")
                                    @if (Context.Session.GetString("Role") != null)
                                    {
                                        <span class="badge bg-light text-dark ms-1">@Context.Session.GetString("Role")</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light" asp-controller="Home" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Leidos QTC Health Services - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
