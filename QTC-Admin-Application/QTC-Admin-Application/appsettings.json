{
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Database=Workflow;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Monitoring": {
        "IntervalMinutes": 5,
        "CpuThreshold": 80,
        "MemoryThreshold": 75,
        "FailedLoginThreshold": 5,
        "ApiUrl": ""
    }
}